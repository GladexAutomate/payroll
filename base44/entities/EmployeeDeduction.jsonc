{
  "name": "EmployeeDeduction",
  "type": "object",
  "properties": {
    "env": {
      "type": "string",
      "enum": [
        "test",
        "prod"
      ],
      "description": "Virtual namespace tag: 'test' for editor preview data, 'prod' for published app data"
    },
    "employee_id": {
      "type": "string",
      "description": "AirtableEmployeeRecord backend record ID"
    },
    "employee_name": {
      "type": "string"
    },
    "company": {
      "type": "string",
      "description": "Company whose payroll this allowance/charge is paid through. Blank = all/default company"
    },
    "branch": {
      "type": "string",
      "description": "Branch under the chosen company this allowance/charge is paid through. Blank = all branches of the company"
    },
    "kind": {
      "type": "string",
      "enum": [
        "allowance",
        "deduction"
      ],
      "default": "deduction",
      "description": "allowance = recurring earning added to pay; deduction = ATD charge subtracted from pay"
    },
    "label": {
      "type": "string",
      "description": "e.g. Transportation Allowance, Cash Advance, Uniform Charge"
    },
    "amount_per_cutoff": {
      "type": "number",
      "description": "Amount applied each cutoff/payroll period"
    },
    "total_amount": {
      "type": "number",
      "description": "For deductions: total charge to be fully paid over multiple cutoffs. 0/blank = open-ended recurring"
    },
    "total_cutoffs": {
      "type": "number",
      "description": "Number of cutoffs to deduct/pay until completion"
    },
    "cutoffs_paid": {
      "type": "number",
      "default": 0,
      "description": "How many cutoffs have already been applied"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Deduction/allowance begins on the cutoff covering this date"
    },
    "recurring": {
      "type": "boolean",
      "default": false,
      "description": "True for ongoing allowances with no end"
    },
    "atd_status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "approved",
        "active",
        "completed",
        "cancelled"
      ],
      "default": "draft",
      "description": "Authorization-To-Deduct approval lifecycle"
    },
    "atd_sent_date": {
      "type": "string"
    },
    "atd_approved_date": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "chain_status": {
      "type": "string",
      "enum": [
        "awaiting_employee",
        "awaiting_mid",
        "awaiting_hr",
        "fully_signed",
        "rejected"
      ],
      "default": "awaiting_employee",
      "description": "Signed approval chain progress; must be fully_signed before atd_status can become active"
    },
    "approval_chain": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": [],
      "description": "Signed steps: { step, required_tier, signer_name, signer_role, signature_url, signed_at }"
    }
  },
  "required": [
    "employee_id",
    "kind",
    "label",
    "amount_per_cutoff"
  ]
}